# Polymarket bot live example configuration
# Copy to .env and fill in the real values.

# ===== Execution mode =====
EXECUTION_MODE=LIVE

# ===== Network / CLOB =====
HOST=https://clob.polymarket.com
CHAIN_ID=137
POLY_MARKET_ORDER_TYPE=FAK

# ===== Wallet / signing =====
# Use the private key that will sign CLOB requests.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Signature type mapping:
# 0 = EOA standalone wallet
# 1 = Polymarket proxy via Magic Link / email / Google
# 2 = Browser wallet / proxy wallet (commonly MetaMask / Rabby users on Polymarket)
POLY_SIGNATURE_TYPE=2

# The funder address must match the wallet that actually holds the funds used by Polymarket.
# For type 0, this is usually your EOA address.
# For type 1 or 2, this is usually your Polymarket proxy/funder address.
POLY_FUNDER_ADDRESS=0xYOUR_FUNDER_OR_PROXY_ADDRESS

# Optional but recommended: the public address derived from PRIVATE_KEY.
POLY_SIGNER_ADDRESS=0xYOUR_SIGNER_ADDRESS

# ===== CLOB L2 credentials =====
# Leave blank initially. Some flows derive them automatically.
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# ===== Optional relayer values =====
RELAYER_API_KEY=
RELAYER_API_ADDRESS=

# ===== Telegram =====
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Optional feed tuning =====
PM_HEARTBEAT_SEC=10
PM_RECV_TIMEOUT_SEC=15
PM_EMPTY_REFRESH_THRESHOLD=3
PM_INVALID_REFRESH_THRESHOLD=5
PM_REFRESH_COOLDOWN_SEC=15
PM_RETRY_DELAY_SEC=5
PM_STALE_QUOTE_SEC=20

# ===== Optional exit guards =====
EXIT_CONFIRMATIONS_REQUIRED=2
EXIT_MAX_PRICE_JUMP_ABS=0.20
EXIT_MAX_PRICE_JUMP_REL=0.50
EXIT_MAX_QUOTE_AGE_SEC=15
